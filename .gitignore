# Alles ignorieren
*

# Aber .gitignore selbst tracken
!.gitignore

# GitHub Actions Workflows tracken
!.github/
!.github/workflows/
!.github/workflows/hugo.yml

# Nur Website-Verzeichnis tracken
!website/

# Innerhalb von website alles tracken
!website/**

# Aber diese Dateien/Directories in website ignorieren
website/themes/
website/public/
website/resources/
website/.hugo_build.lock
website/.github/
